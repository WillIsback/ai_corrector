---
import StarlightPage from "@astrojs/starlight/components/StarlightPage.astro";
---

<StarlightPage
  frontmatter={{
    title: "AI Corrector",
    template: "splash",
    hero: {
      tagline: "Correction et reformulation de texte français — LLM + LanguageTool",
      actions: [
        { text: "Démarrage rapide →", link: "getting-started/", variant: "primary" },
        { text: "GitHub", link: "https://github.com/WillIsback/ai_corrector", variant: "secondary" },
      ],
    },
  }}
>
  <!-- Badge Open Source -->
  <div class="hero-badges">
    <span class="badge">Open Source · MIT</span>
    <span class="badge">Bun + React</span>
    <span class="badge">Self-hosted</span>
  </div>

  <!-- Feature strip -->
  <div class="feature-strip">
    <span>✏️ 4 modes de rédaction</span>
    <span class="sep">·</span>
    <span>🔌 2 moteurs commutables</span>
    <span class="sep">·</span>
    <span>⚡ Streaming SSE</span>
    <span class="sep">·</span>
    <span>📊 OpenTelemetry</span>
  </div>

  <!-- Getting Started -->
  <div class="section-header">
    <h2 class="section-title">Prise en main</h2>
    <p class="section-sub">Lancez AI Corrector en quelques minutes</p>
  </div>
  <ul class="card-grid">
    <li class="card">
      <a href="getting-started/">
        <span class="card-icon">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3"/></svg>
        </span>
        <strong>Démarrage rapide</strong>
        <span>Lancez AI Corrector en 5 minutes via script ou Docker.</span>
      </a>
    </li>
    <li class="card">
      <a href="getting-started/installation">
        <span class="card-icon">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        </span>
        <strong>Installation</strong>
        <span>Script interactif, Docker Compose ou mode développement Bun.</span>
      </a>
    </li>
    <li class="card">
      <a href="getting-started/configuration">
        <span class="card-icon">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.07 4.93A10 10 0 0 0 4.93 19.07M4.93 4.93a10 10 0 0 0 14.14 14.14"/><path d="M12 2v2M12 20v2M2 12h2M20 12h2"/></svg>
        </span>
        <strong>Configuration</strong>
        <span>Variables d'environnement : LLM_TARGET, LT_TARGET, OTEL…</span>
      </a>
    </li>
  </ul>

  <!-- Core -->
  <div class="section-header">
    <h2 class="section-title">Fonctionnalités principales</h2>
    <p class="section-sub">Comprendre le moteur de correction</p>
  </div>
  <ul class="card-grid">
    <li class="card">
      <a href="core/correction-modes">
        <span class="card-icon">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
        </span>
        <strong>Modes de correction</strong>
        <span>Formel, semi-formel, informel, technique — avec prompts système détaillés.</span>
      </a>
    </li>
    <li class="card">
      <a href="core/engine-selector">
        <span class="card-icon">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
        </span>
        <strong>Sélecteur de moteur</strong>
        <span>Basculez entre LLM (streaming SSE) et LanguageTool (règles grammaticales).</span>
      </a>
    </li>
    <li class="card">
      <a href="core/diff-view">
        <span class="card-icon">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
        </span>
        <strong>Panneau de résultat</strong>
        <span>Texte corrigé, stats de traitement et liste avant/après des corrections.</span>
      </a>
    </li>
  </ul>

  <!-- Advanced -->
  <div class="section-header">
    <h2 class="section-title">Fonctionnalités avancées</h2>
    <p class="section-sub">Configuration et déploiement</p>
  </div>
  <ul class="card-grid">
    <li class="card">
      <a href="advanced/custom-words">
        <span class="card-icon">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
        </span>
        <strong>Mots personnalisés</strong>
        <span>Dictionnaire de termes valides persisté sur disque via API REST.</span>
      </a>
    </li>
    <li class="card">
      <a href="advanced/telemetry">
        <span class="card-icon">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
        </span>
        <strong>Télémétrie</strong>
        <span>Tracing OpenTelemetry des appels LLM vers Phoenix, Jaeger ou Grafana Tempo.</span>
      </a>
    </li>
    <li class="card">
      <a href="advanced/docker-deploy">
        <span class="card-icon">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="8" rx="2" ry="2"/><rect x="2" y="14" width="20" height="8" rx="2" ry="2"/><line x1="6" y1="6" x2="6.01" y2="6"/><line x1="6" y1="18" x2="6.01" y2="18"/></svg>
        </span>
        <strong>Déploiement Docker</strong>
        <span>Stack production avec Traefik, healthchecks et volume persistant.</span>
      </a>
    </li>
  </ul>

  <!-- References -->
  <div class="section-header">
    <h2 class="section-title">Références</h2>
    <p class="section-sub">Documentation technique complète</p>
  </div>
  <ul class="card-grid">
    <li class="card">
      <a href="references/api">
        <span class="card-icon">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
        </span>
        <strong>Référence API</strong>
        <span>Endpoints SSE LLM, proxy LanguageTool, mots valides.</span>
      </a>
    </li>
    <li class="card">
      <a href="references/architecture">
        <span class="card-icon">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
        </span>
        <strong>Architecture</strong>
        <span>Flux de correction, rôle du serveur Bun, télémétrie.</span>
      </a>
    </li>
    <li class="card">
      <a href="references/faq">
        <span class="card-icon">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
        </span>
        <strong>FAQ</strong>
        <span>Dépannage : LanguageTool, LLM, CORS, modèle non détecté.</span>
      </a>
    </li>
  </ul>
</StarlightPage>

<style>
  /* ── Hero badges ─────────────────────────────────────────── */
  .hero-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    justify-content: center;
    margin: -0.5rem 0 1.5rem;
  }
  .badge {
    display: inline-block;
    background: #eef2ff;
    color: #4338ca;
    border: 1px solid #c7d2fe;
    border-radius: 999px;
    font-size: 0.72rem;
    font-weight: 600;
    padding: 0.2rem 0.75rem;
    letter-spacing: 0.01em;
  }
  :global([data-theme="dark"]) .badge {
    background: #1e1b4b;
    color: #a5b4fc;
    border-color: #3730a3;
  }

  /* ── Feature strip ────────────────────────────────────────── */
  .feature-strip {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 0.5rem 0.75rem;
    margin: 0 auto 2.5rem;
    font-size: 0.85rem;
    color: var(--sl-color-gray-3);
  }
  .feature-strip .sep {
    color: var(--sl-color-gray-5);
  }

  /* ── Section headers ──────────────────────────────────────── */
  .section-header {
    margin: 2.5rem 0 1rem;
  }
  .section-title {
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--sl-color-white);
    margin: 0 0 0.2rem;
    border-left: 3px solid #6366f1;
    padding-left: 0.65rem;
  }
  .section-sub {
    font-size: 0.82rem;
    color: var(--sl-color-gray-3);
    margin: 0;
    padding-left: 0.9rem;
  }

  /* ── Card grid ────────────────────────────────────────────── */
  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(17rem, 1fr));
    gap: 0.85rem;
    list-style: none;
    padding: 0;
    margin: 0 0 0.5rem;
  }
  .card {
    border: 1px solid #e5e7eb;
    border-radius: 0.75rem;
    background: #ffffff;
    transition: transform 0.15s ease, box-shadow 0.15s ease, border-color 0.15s ease;
  }
  .card:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(99, 102, 241, 0.1);
    border-color: #a5b4fc;
  }
  :global([data-theme="dark"]) .card {
    background: #1e1e2e;
    border-color: #2d2d3f;
  }
  :global([data-theme="dark"]) .card:hover {
    border-color: #6366f1;
    box-shadow: 0 6px 20px rgba(99, 102, 241, 0.2);
  }
  .card a {
    display: grid;
    grid-template-rows: auto auto 1fr;
    gap: 0.25rem;
    padding: 1rem 1.1rem;
    text-decoration: none;
    color: inherit;
    height: 100%;
  }
  .card-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    background: #eef2ff;
    border-radius: 0.5rem;
    margin-bottom: 0.4rem;
    color: #6366f1;
  }
  .card-icon svg {
    width: 1rem;
    height: 1rem;
  }
  :global([data-theme="dark"]) .card-icon {
    background: #1e1b4b;
    color: #a5b4fc;
  }
  .card strong {
    display: block;
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--sl-color-white);
  }
  .card span:last-child {
    font-size: 0.82rem;
    color: var(--sl-color-gray-3);
    line-height: 1.4;
  }
</style>
